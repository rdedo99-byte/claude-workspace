{
  "_comment": "Copy to config.json and adapt to your machine. config.json is git-ignored (keeps your real paths local).",
  "ollama": {
    "host": "http://localhost:11434",
    "model": "qwen3-coder:30b",
    "temperature": 0.1,
    "keep_alive": 0,
    "keep_alive_cpu": 300,
    "timeout_s": 600
  },
  "traffic_cop": {
    "vram_pct_threshold": 0.85,
    "train_match": "train.py"
  },
  "runner": {
    "default_timeout_s": 300,
    "max_attempts": 3,
    "bridge_freeze_dir": "~/.claude/centaur/frozen",
    "deny_substrings": ["train.py", "train.sh"],
    "allow_interpreters": ["python3", "/usr/bin/python3"]
  }
}
