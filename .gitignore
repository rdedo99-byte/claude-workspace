# Claude global config — commit ONLY the portable, domain-neutral system.
# Everything else (credentials, project data, caches) stays local.

# 1) ignore everything at root by default
/*

# 2) whitelist the portable system files
!/CLAUDE.md
!/commands.md
!/workflow.md
!/settings.json
!/README.md
!/.gitignore

# 3) families/ is tracked but SHIPS EMPTY:
#    generate per-family agents locally with `agents family init`.
!/families/
/families/*
!/families/.gitkeep

# 4) centaur/ (Ollama execution bridge): ship the CODE + template, NOT machine state.
#    Shipped: the python package, requirements, config.example.json, README.
#    NOT shipped: .venv/ (recreate via pip), frozen/ (throwaway), specs/ (project-specific),
#                 and the REAL config.json (holds your local paths → stays local).
!/centaur/
/centaur/*
!/centaur/README.md
!/centaur/requirements.txt
!/centaur/config.example.json
!/centaur/centaur/
/centaur/centaur/*
!/centaur/centaur/*.py
